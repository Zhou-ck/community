/* 文章场景相关 */
page.data-v-18804380 {
  background-color: #f8f9fa;
}
.login-container.data-v-18804380 {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6fcfd 60%, #eafcff 100%);
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
}
/* 头部logo区域 */
.logo-content.data-v-18804380 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0 80rpx;
  text-align: center;
}
.logo-image.data-v-18804380 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}
.title.data-v-18804380 {
  font-size: 48rpx;
  font-weight: bold;
  color: #4e4e4e;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}
/* 登录表单 */
.login-form.data-v-18804380 {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.1);
}
/* 输入框样式 */
.input-wrapper.data-v-18804380 {
  position: relative;
  margin-bottom: 40rpx;
  /* 固定间距，为错误信息预留空间 */
}
.input-item.data-v-18804380 {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 30rpx;
  height: 100rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}
.input-item.data-v-18804380:focus-within {
  border-color: #3FA9E7;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(63, 169, 231, 0.1);
}
.input-item.error.data-v-18804380 {
  border-color: #ff4757;
  background: #fff5f5;
}
.input-item.error.data-v-18804380:focus-within {
  border-color: #ff4757;
  box-shadow: 0 0 0 4rpx rgba(255, 71, 87, 0.1);
}
.error-message.data-v-18804380 {
  position: absolute;
  top: 100rpx;
  /* 紧贴输入框下方 */
  left: 30rpx;
  color: #ff4757;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
  /* 防止换行 */
}
.input-icon.data-v-18804380 {
  margin-right: 20rpx;
  flex-shrink: 0;
}
.input.data-v-18804380 {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  height: 100%;
  border: none;
  outline: none;
}
.input.data-v-18804380::-webkit-input-placeholder {
  color: #999;
}
.input.data-v-18804380::placeholder {
  color: #999;
}
/* 验证码特殊样式 */
.captcha-container.data-v-18804380 {
  display: flex;
  align-items: center;
  gap: 25rpx;
}
.captcha-input-item.data-v-18804380 {
  flex: 1;
  min-width: 0;
  /* 确保可以正常缩放 */
}
.captcha-image.data-v-18804380 {
  flex-shrink: 0;
}
.captcha-img.data-v-18804380 {
  width: 200rpx;
  height: 90rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d0d0d0;
  background: #f8f9fa;
  cursor: pointer;
  display: block;
}
