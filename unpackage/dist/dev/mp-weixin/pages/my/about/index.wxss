/* 文章场景相关 */
page.data-v-02c203b4 {
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
}
.page-container.data-v-02c203b4 {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
}
/* 内容区域 */
.content-section.data-v-02c203b4 {
  padding: 30rpx;
}
/* Logo卡片 */
.logo-card.data-v-02c203b4 {
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.logo-wrapper.data-v-02c203b4 {
  margin-bottom: 30rpx;
}
.app-logo.data-v-02c203b4 {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(168, 230, 207, 0.3);
}
.app-info.data-v-02c203b4 {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.app-name.data-v-02c203b4 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}
.app-desc.data-v-02c203b4 {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-style: italic;
}
.version-badge.data-v-02c203b4 {
  background: linear-gradient(135deg, #a8e6cf 0%, #88d8a3 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(168, 230, 207, 0.3);
}
.version-text.data-v-02c203b4 {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}
/* 信息卡片 */
.info-cards.data-v-02c203b4 {
  margin-bottom: 30rpx;
}
.info-card.data-v-02c203b4 {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
}
.clickable-card.data-v-02c203b4 {
  transition: all 0.3s ease;
  cursor: pointer;
}
.clickable-card.data-v-02c203b4:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}
.card-icon.data-v-02c203b4 {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}
.card-content.data-v-02c203b4 {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.card-label.data-v-02c203b4 {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.card-value.data-v-02c203b4 {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
.link-text.data-v-02c203b4 {
  color: #a8e6cf !important;
  text-decoration: underline;
}
.phone-text.data-v-02c203b4 {
  color: #4facfe !important;
  font-weight: 600;
}
.email-text.data-v-02c203b4 {
  color: #333 !important;
}
.card-arrow.data-v-02c203b4 {
  margin-left: auto;
  padding-left: 20rpx;
}
/* 版权信息 */
.copyright-section.data-v-02c203b4 {
  padding: 40rpx 30rpx;
  text-align: center;
}
.copyright-text.data-v-02c203b4 {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.copyright-desc.data-v-02c203b4 {
  display: block;
  font-size: 22rpx;
  color: #bbb;
}
/* 图标主题色 - 统一背景色 */
.version-icon.data-v-02c203b4,
.email-icon.data-v-02c203b4,
.phone-icon.data-v-02c203b4,
.web-icon.data-v-02c203b4 {
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8A3 100%);
}

