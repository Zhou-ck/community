<view class="address-container"><scroll-view class="address-list" style="{{'height:'+('calc(100vh - '+(180+safeAreaBottom)+'rpx)')+';'}}" scroll-y="{{true}}"><block wx:if="{{$root.g0===0}}"><view class="empty-address"><block wx:if="{{false}}"><image class="empty-img" src="/static/images/empty-address.png" mode="aspectFit"></image></block><view class="empty-icon-box"><uni-icons vue-id="6d5f6059-1" type="location-filled" size="60" color="#e0e0e0" bind:__l="__l"></uni-icons></view><text class="empty-text">暂无服务地址</text><text class="empty-sub">点击底部按钮添加新地址</text></view></block><block wx:else><block wx:for="{{$root.l0}}" wx:for-item="address" wx:for-index="index" wx:key="addressId"><view class="{{['address-item',(isFromBooking&&selectedAddressId===address.$orig.addressId)?'selected':'']}}"><view data-event-opts="{{[['tap',[['selectAddressByIndex',[index]]]]]}}" class="address-content" bindtap="__e"><view class="header-row"><view class="info-left"><text class="name">{{address.$orig.contactName}}</text><text class="phone">{{address.$orig.contactPhone}}</text></view><view class="tags-row"><block wx:if="{{address.$orig.isDefault}}"><text class="tag default">默认</text></block><block wx:if="{{isFromBooking&&selectedAddressId===address.$orig.addressId}}"><text class="tag selected">已选</text></block></view></view><view class="address-row"><view class="icon-box"><uni-icons vue-id="{{'6d5f6059-2-'+index}}" type="location-filled" size="18" color="#3ec6c6" bind:__l="__l"></uni-icons></view><view class="address-text-box"><text class="area">{{address.m0}}</text><text class="detail">{{address.$orig.detailAddress||''}}</text></view></view></view><view class="divider"></view><view class="address-actions"><view class="action-left"><view data-event-opts="{{[['tap',[['deleteAddress',[index]]]]]}}" class="action-btn delete" catchtap="__e"><uni-icons vue-id="{{'6d5f6059-3-'+index}}" type="trash" size="16" color="#ff5555" bind:__l="__l"></uni-icons><text>删除</text></view></view><view class="action-right"><view data-event-opts="{{[['tap',[['copyAddress',[index]]]]]}}" class="action-btn copy" catchtap="__e"><uni-icons vue-id="{{'6d5f6059-4-'+index}}" type="navigate" size="16" color="#666" bind:__l="__l"></uni-icons><text>复制</text></view><view data-event-opts="{{[['tap',[['editAddress',[index]]]]]}}" class="action-btn edit" catchtap="__e"><uni-icons vue-id="{{'6d5f6059-5-'+index}}" type="compose" size="16" color="#fff" bind:__l="__l"></uni-icons><text>编辑</text></view></view></view></view></block></block><view style="height:20rpx;"></view></scroll-view><view class="add-address-bar" style="{{'padding-bottom:'+(safeAreaBottom+'rpx')+';'}}"><view class="add-btn" hover-class="add-btn-hover" data-event-opts="{{[['tap',[['showAddressPopup']]]]}}" bindtap="__e"><uni-icons style="margin-right:10rpx;" vue-id="6d5f6059-6" type="plusempty" size="20" color="#fff" bind:__l="__l"></uni-icons><text>新增服务地址</text></view></view><block wx:if="{{showPopup}}"><view data-event-opts="{{[['tap',[['closePopup',['$event']]]]]}}" class="{{['popup-mask',(showPopup)?'show':'']}}" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="{{['popup-container',(showPopup)?'show':'']}}" catchtap="__e"><view class="popup-header"><text class="title">{{isEdit?'编辑服务地址':'新增服务地址'}}</text><view data-event-opts="{{[['tap',[['closePopup',['$event']]]]]}}" class="close-btn" bindtap="__e"><uni-icons vue-id="6d5f6059-7" type="closeempty" size="24" color="#999" bind:__l="__l"></uni-icons></view></view><scroll-view class="form-content" scroll-y="{{true}}"><view class="form-group"><view class="form-item"><text class="label required">联系人</text><input type="text" placeholder="请输入联系人姓名" placeholder-class="input-placeholder" data-event-opts="{{[['input',[['__set_model',['$0','contactName','$event',[]],['addressForm']]]]]}}" value="{{addressForm.contactName}}" bindinput="__e"/></view><view class="form-item"><text class="label required">手机号码</text><input type="number" placeholder="请输入手机号码" maxlength="11" placeholder-class="input-placeholder" data-event-opts="{{[['input',[['__set_model',['$0','contactPhone','$event',[]],['addressForm']],['handlePhoneInput',['$event']]]]]}}" value="{{addressForm.contactPhone}}" bindinput="__e"/></view><view class="form-item"><text class="label required">所在地区</text><picker class="region-picker" mode="region" data-event-opts="{{[['change',[['onRegionChange',['$event']]]]]}}" bindchange="__e"><view class="picker-view"><block wx:if="{{!addressForm.province}}"><text class="placeholder">请选择所在地区</text></block><block wx:else><text class="value">{{$root.m1}}</text></block><uni-icons vue-id="6d5f6059-8" type="right" size="16" color="#ccc" bind:__l="__l"></uni-icons></view></picker></view><view class="form-item column"><text class="label required">详细地址</text><textarea placeholder="请输入详细地址，如街道、楼牌号等" placeholder-class="input-placeholder" disable-default-padding="{{true}}" data-event-opts="{{[['input',[['__set_model',['$0','detailAddress','$event',[]],['addressForm']]]]]}}" value="{{addressForm.detailAddress}}" bindinput="__e"></textarea></view><view class="form-item column"><text class="label">备注信息</text><textarea placeholder="请输入备注信息（选填）" placeholder-class="input-placeholder" disable-default-padding="{{true}}" data-event-opts="{{[['input',[['__set_model',['$0','remark','$event',[]],['addressForm']]]]]}}" value="{{addressForm.remark}}" bindinput="__e"></textarea></view></view><view class="form-group mt-20"><view class="form-item switch-item"><view class="switch-label"><text class="main-text">设为默认地址</text><text class="sub-text">下单时将优先使用该地址</text></view><switch style="transform:scale(0.8);" checked="{{addressForm.isDefault==='1'}}" color="#3ec6c6" data-event-opts="{{[['change',[['onDefaultChange',['$event']]]]]}}" bindchange="__e"></switch></view></view></scroll-view><view class="popup-footer" style="{{'padding-bottom:'+(safeAreaBottom+'rpx')+';'}}"><view class="save-btn" hover-class="save-btn-hover" data-event-opts="{{[['tap',[['saveAddress',['$event']]]]]}}" bindtap="__e"><text>保存地址</text></view></view></view></view></block></view>