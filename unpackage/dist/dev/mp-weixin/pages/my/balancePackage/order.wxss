
.order-container.data-v-07f9923a {
	min-height: 100vh;
	background-color: #f5f5f5;
}

/* 状态筛选标签 */
.status-tabs.data-v-07f9923a {
	background-color: #fff;
	display: flex;
	padding: 0 15px;
	border-bottom: 1px solid #EBEEF5;
}
.status-tab.data-v-07f9923a {
	flex: 1;
	text-align: center;
	padding: 15px 0;
	position: relative;
	cursor: pointer;
}
.tab-text.data-v-07f9923a {
	font-size: 15px;
	color: #909399;
	transition: color 0.3s;
}
.status-tab.active .tab-text.data-v-07f9923a {
	color: #5DD5C0;
	font-weight: 600;
}
.tab-underline.data-v-07f9923a {
	position: absolute;
	bottom: 0;
	left: 50%;
	-webkit-transform: translateX(-50%);
	        transform: translateX(-50%);
	width: 40px;
	height: 3px;
	background-color: #5DD5C0;
	border-radius: 2px;
}

/* 订单列表 */
.order-list.data-v-07f9923a {
	padding: 15px;
}
.order-card.data-v-07f9923a {
	background-color: #fff;
	border-radius: 12px;
	margin-bottom: 15px;
	padding: 15px;
	box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

/* 订单头部 */
.order-header.data-v-07f9923a {
	display: flex;
	justify-content: space-between;
	align-items: flex-start;
	padding-bottom: 12px;
	border-bottom: 1px solid #F5F7FA;
	margin-bottom: 12px;
}
.order-info.data-v-07f9923a {
	flex: 1;
	display: flex;
	flex-direction: column;
}
.order-no.data-v-07f9923a {
	font-size: 13px;
	color: #606266;
	margin-bottom: 4px;
	font-family: monospace;
}
.order-time.data-v-07f9923a {
	font-size: 12px;
	color: #909399;
}
.order-status.data-v-07f9923a {
	padding: 4px 12px;
	border-radius: 12px;
	font-size: 12px;
	font-weight: 500;
}
.status-pending.data-v-07f9923a {
	background-color: #FFF3E0;
	color: #FF9800;
}
.status-paid.data-v-07f9923a {
	background-color: rgba(93, 213, 192, 0.1);
	color: #5DD5C0;
}
.status-refund.data-v-07f9923a {
	background-color: #F5F7FA;
	color: #909399;
}
.status-canceled.data-v-07f9923a {
	background-color: #F5F7FA;
	color: #909399;
}

/* 订单内容 */
.order-content.data-v-07f9923a {
	display: flex;
	align-items: center;
	margin-bottom: 12px;
}
.package-icon.data-v-07f9923a {
	font-size: 32px;
	margin-right: 12px;
}
.package-info.data-v-07f9923a {
	flex: 1;
}
.package-name.data-v-07f9923a {
	font-size: 15px;
	font-weight: 600;
	color: #303133;
	display: block;
	margin-bottom: 6px;
}
.package-details.data-v-07f9923a {
	display: flex;
	flex-wrap: wrap;
	gap: 8px;
}
.detail-item.data-v-07f9923a {
	font-size: 12px;
	color: #909399;
	padding: 2px 8px;
	background-color: #F5F7FA;
	border-radius: 4px;
}
.package-price.data-v-07f9923a {
	display: flex;
	align-items: baseline;
	color: #F56C6C;
}
.price-symbol.data-v-07f9923a {
	font-size: 14px;
	font-weight: 600;
}
.price-amount.data-v-07f9923a {
	font-size: 20px;
	font-weight: 600;
	font-family: DINAlternate-Bold, sans-serif;
}

/* 订单操作 */
.order-actions.data-v-07f9923a {
	display: flex;
	justify-content: flex-end;
	gap: 10px;
	padding-top: 12px;
	border-top: 1px solid #F5F7FA;
}
.action-btn.data-v-07f9923a {
	padding: 8px 20px;
	border-radius: 20px;
	font-size: 13px;
	font-weight: 500;
	cursor: pointer;
	transition: all 0.3s;
}
.detail-btn.data-v-07f9923a {
	background-color: #F5F7FA;
	color: #606266;
}
.detail-btn.data-v-07f9923a:active {
	background-color: #EBEEF5;
}
.pay-btn.data-v-07f9923a {
	background: linear-gradient(135deg, #5DD5C0 0%, #4EC9B0 100%);
	color: #fff;
	box-shadow: 0 4px 10px rgba(78, 201, 176, 0.3);
}
.pay-btn.data-v-07f9923a:active {
	-webkit-transform: scale(0.95);
	        transform: scale(0.95);
}
.cancel-btn.data-v-07f9923a {
	background-color: #FFF3E0;
	color: #FF9800;
	border: 1px solid #FFE0B2;
}
.cancel-btn.data-v-07f9923a:active {
	background-color: #FFE0B2;
}
.delete-btn.data-v-07f9923a {
	background-color: #FFEBEE;
	color: #F56C6C;
	border: 1px solid #FFCDD2;
}
.delete-btn.data-v-07f9923a:active {
	background-color: #FFCDD2;
}

/* 空状态 */
.empty-state.data-v-07f9923a {
	text-align: center;
	padding: 80px 20px;
}
.empty-icon.data-v-07f9923a {
	font-size: 64px;
	display: block;
	margin-bottom: 16px;
	opacity: 0.5;
}
.empty-text.data-v-07f9923a {
	font-size: 14px;
	color: #909399;
}

/* 订单详情弹窗 */
.order-detail-modal.data-v-07f9923a {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background-color: rgba(0, 0, 0, 0.5);
	display: flex;
	align-items: center;
	justify-content: center;
	z-index: 9999;
}
.detail-modal-content.data-v-07f9923a {
	width: 90%;
	max-width: 500px;
	max-height: 80vh;
	background-color: #fff;
	border-radius: 16px;
	overflow: hidden;
	display: flex;
	flex-direction: column;
}
.detail-modal-header.data-v-07f9923a {
	padding: 20px;
	border-bottom: 1px solid #EBEEF5;
	display: flex;
	justify-content: space-between;
	align-items: center;
	background-color: #F9FAFC;
}
.detail-modal-title.data-v-07f9923a {
	font-size: 18px;
	font-weight: 600;
	color: #303133;
}
.detail-close-btn.data-v-07f9923a {
	width: 30px;
	height: 30px;
	border-radius: 50%;
	background-color: #F0F0F0;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 16px;
	color: #909399;
	cursor: pointer;
}
.detail-close-btn.data-v-07f9923a:active {
	background-color: #E0E0E0;
}
.detail-modal-body.data-v-07f9923a {
	flex: 1;
	overflow-y: auto;
	padding: 0 20px 20px;
}
.detail-section.data-v-07f9923a {
	margin-top: 20px;
}
.section-title.data-v-07f9923a {
	font-size: 16px;
	font-weight: 600;
	color: #303133;
	margin-bottom: 12px;
	padding-bottom: 8px;
	border-bottom: 2px solid #5DD5C0;
	display: inline-block;
}
.detail-info-item.data-v-07f9923a {
	display: flex;
	justify-content: space-between;
	align-items: flex-start;
	padding: 8px 0;
	border-bottom: 1px solid #F5F7FA;
	line-height: 1.5;
}
.detail-info-item.data-v-07f9923a:last-child {
	border-bottom: none;
}
.info-label.data-v-07f9923a {
	font-size: 14px;
	color: #909399;
	min-width: 80px;
	flex-shrink: 0;
}
.info-value.data-v-07f9923a {
	font-size: 14px;
	color: #303133;
	text-align: right;
	flex: 1;
	word-break: break-all;
}
.order-no-text.data-v-07f9923a {
	font-family: monospace;
	font-size: 12px;
	color: #606266;
}
.price-text.data-v-07f9923a {
	color: #F56C6C;
	font-weight: 600;
	font-size: 15px;
}
.status-text.data-v-07f9923a {
	color: #5DD5C0;
	font-weight: 500;
}

