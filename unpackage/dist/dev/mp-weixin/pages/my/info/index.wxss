/* 文章场景相关 */
page.data-v-7062ca6a {
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
}
.page-container.data-v-7062ca6a {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
}
/* 头部区域 */
.header-section.data-v-7062ca6a {
  background: linear-gradient(135deg, #a8e6cf 0%, #88d8a3 100%);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}
.header-section.data-v-7062ca6a::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  -webkit-transform: rotate(15deg);
          transform: rotate(15deg);
}
.status-bar.data-v-7062ca6a {
  height: 25px;
}
.header-content.data-v-7062ca6a {
  padding: 40rpx 30rpx;
  position: relative;
  z-index: 2;
}
.header-title.data-v-7062ca6a {
  text-align: center;
}
.title-text.data-v-7062ca6a {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}
.subtitle-text.data-v-7062ca6a {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-style: italic;
}
/* 内容区域 */
.content-section.data-v-7062ca6a {
  margin-top: -20rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 3;
}
/* 头像显示卡片 */
.avatar-display-card.data-v-7062ca6a {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
}
.avatar-wrapper.data-v-7062ca6a {
  margin-right: 30rpx;
}
.default-avatar.data-v-7062ca6a, .user-avatar.data-v-7062ca6a {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f8f9fa;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(168, 230, 207, 0.3);
}
.user-avatar.data-v-7062ca6a {
  border: 4rpx solid rgba(168, 230, 207, 0.3);
}
.avatar-info.data-v-7062ca6a {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.user-name.data-v-7062ca6a {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.user-role.data-v-7062ca6a {
  font-size: 26rpx;
  color: #666;
}
/* 表单容器 */
.form-container.data-v-7062ca6a {
  margin-bottom: 40rpx;
}
/* 表单卡片 */
.form-card.data-v-7062ca6a {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: flex-start;
}
.readonly-card.data-v-7062ca6a {
  opacity: 0.6;
}
.form-icon.data-v-7062ca6a {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}
.form-content.data-v-7062ca6a {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.form-label.data-v-7062ca6a {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.custom-input.data-v-7062ca6a {
  margin-top: 8rpx;
}
.gender-selector.data-v-7062ca6a {
  margin-top: 8rpx;
}
.readonly-value.data-v-7062ca6a {
  margin-top: 8rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}
.readonly-text.data-v-7062ca6a {
  font-size: 28rpx;
  color: #666;
}
/* 错误提示样式 */
.error-message.data-v-7062ca6a {
  margin-top: 12rpx;
  padding-left: 4rpx;
}
.error-text.data-v-7062ca6a {
  font-size: 24rpx;
  color: #ff4757;
  line-height: 1.2;
}
/* 提交按钮 */
.submit-container.data-v-7062ca6a {
  padding: 20rpx 0 40rpx;
}
.submit-btn.data-v-7062ca6a {
  width: 100%;
  height: 88rpx;
  background: #88d8a3;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(168, 230, 207, 0.4);
  transition: all 0.3s ease;
}
.submit-btn.data-v-7062ca6a:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(168, 230, 207, 0.6);
}
.submit-btn.disabled.data-v-7062ca6a {
  background: #e0e0e0 !important;
  box-shadow: none !important;
  cursor: not-allowed;
}
.submit-btn.disabled.data-v-7062ca6a:active {
  -webkit-transform: none !important;
          transform: none !important;
}
.submit-text.data-v-7062ca6a {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}
.submit-btn.disabled .submit-text.data-v-7062ca6a {
  color: #999 !important;
}
/* 图标颜色主题 - 统一背景色 */
.person-icon.data-v-7062ca6a,
.account-icon.data-v-7062ca6a,
.phone-icon.data-v-7062ca6a,
.email-icon.data-v-7062ca6a,
.job-icon.data-v-7062ca6a,
.time-icon.data-v-7062ca6a,
.gender-icon.data-v-7062ca6a,
.role-icon.data-v-7062ca6a {
  background: #65d289;
}
.card-content.data-v-7062ca6a {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.card-label.data-v-7062ca6a {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.card-value.data-v-7062ca6a {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
