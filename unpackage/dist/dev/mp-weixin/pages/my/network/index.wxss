
.network-config-page.data-v-43f32807 {
	min-height: 100vh;
	background: #f5f5f5;
}

/* 提示信息 */
.notice-box.data-v-43f32807 {
	padding: 24rpx 32rpx;
	background: #fff;
	margin-bottom: 24rpx;
}
.notice-text.data-v-43f32807 {
	display: block;
	font-size: 26rpx;
	color: #f44336;
	line-height: 40rpx;
	margin-bottom: 8rpx;
}
.notice-text.data-v-43f32807:last-child {
	margin-bottom: 0;
}

/* 表单项 */
.form-item.data-v-43f32807 {
	background: #fff;
	padding: 32rpx;
	margin-bottom: 2rpx;
}
.label-row.data-v-43f32807 {
	display: flex;
	align-items: center;
	margin-bottom: 24rpx;
}
.label-required.data-v-43f32807 {
	color: #f44336;
	font-size: 32rpx;
	margin-right: 4rpx;
}
.label-text.data-v-43f32807 {
	font-size: 30rpx;
	color: #333;
	font-weight: 500;
}
.input-row.data-v-43f32807 {
	display: flex;
	align-items: center;
	gap: 16rpx;
	position: relative;
}
.wifi-input.data-v-43f32807 {
	flex: 1;
	height: 80rpx;
	padding: 0 24rpx;
	background: #f8f8f8;
	border-radius: 12rpx;
	font-size: 28rpx;
	color: #333;
}
.input-placeholder.data-v-43f32807 {
	color: #999;
}
.get-wifi-btn.data-v-43f32807 {
	flex-shrink: 0;
	height: 80rpx;
	padding: 0 24rpx;
	background: linear-gradient(135deg, #3ec6c6 0%, #36b3b3 100%);
	color: #fff;
	font-size: 26rpx;
	border-radius: 12rpx;
	border: none;
	line-height: 80rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}
.get-wifi-btn.data-v-43f32807::after {
	border: none;
}
.password-wrapper.data-v-43f32807 {
	position: relative;
	display: flex;
	align-items: center;
}
.password-input.data-v-43f32807 {
	padding-right: 80rpx;
}
.eye-icon.data-v-43f32807 {
	position: absolute;
	right: 24rpx;
	width: 48rpx;
	height: 48rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	z-index: 10;
	cursor: pointer;
}

/* 使用上次配置按钮 */
.last-config-btn.data-v-43f32807 {
	padding: 32rpx;
	text-align: center;
}
.last-config-text.data-v-43f32807 {
	font-size: 28rpx;
	color: #3ec6c6;
	font-weight: 500;
}

/* 操作按钮 */
.action-buttons.data-v-43f32807 {
	display: flex;
	gap: 24rpx;
	padding: 48rpx 32rpx;
}
.reset-btn.data-v-43f32807,
.confirm-btn.data-v-43f32807 {
	flex: 1;
	height: 88rpx;
	line-height: 88rpx;
	border-radius: 12rpx;
	font-size: 32rpx;
	font-weight: 500;
	border: none;
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 0;
}
.reset-btn.data-v-43f32807::after,
.confirm-btn.data-v-43f32807::after {
	border: none;
}
.reset-btn.data-v-43f32807 {
	background: #f44336;
	color: #fff;
}
.confirm-btn.data-v-43f32807 {
	background: #4caf50;
	color: #fff;
}
.reset-btn.data-v-43f32807:active {
	opacity: 0.8;
}
.confirm-btn.data-v-43f32807:active {
	opacity: 0.8;
}

