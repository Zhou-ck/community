<view class="order-detail-page data-v-57d42baa"><scroll-view class="content-wrapper data-v-57d42baa" scroll-y="{{true}}"><block wx:if="{{orderInfo}}"><view class="info-card data-v-57d42baa"><view class="card-header data-v-57d42baa"><view class="header-title data-v-57d42baa"><uni-icons class="header-icon data-v-57d42baa" vue-id="a2b0478a-1" type="shop" size="18" color="#333" bind:__l="__l"></uni-icons><text class="data-v-57d42baa">服务信息</text></view><text class="order-no data-v-57d42baa">{{"NO."+orderInfo.id}}</text></view><view class="service-content data-v-57d42baa"><image class="service-image data-v-57d42baa" src="{{$root.m0}}" mode="aspectFill"></image><view class="service-detail data-v-57d42baa"><text class="service-name data-v-57d42baa">{{orderInfo.serviceName}}</text><block wx:if="{{orderInfo.serviceDesc}}"><text class="service-desc data-v-57d42baa">{{orderInfo.serviceDesc}}</text></block><block wx:if="{{orderInfo.status==='completed'}}"><view class="service-tags data-v-57d42baa"><text class="tag data-v-57d42baa">已完成</text></view></block></view></view></view></block><block wx:if="{{orderInfo}}"><view class="info-card data-v-57d42baa"><view class="card-header data-v-57d42baa"><view class="header-title data-v-57d42baa"><uni-icons class="header-icon data-v-57d42baa" vue-id="a2b0478a-2" type="calendar" size="18" color="#333" bind:__l="__l"></uni-icons><text class="data-v-57d42baa">预约信息</text></view></view><view class="info-list data-v-57d42baa"><view class="info-item data-v-57d42baa"><text class="info-label data-v-57d42baa">联系人</text><view class="info-value-wrapper data-v-57d42baa"><text class="info-value data-v-57d42baa">{{orderInfo.contactName}}</text></view></view><view class="divider data-v-57d42baa"></view><view class="info-item data-v-57d42baa"><text class="info-label data-v-57d42baa">联系电话</text><view data-event-opts="{{[['tap',[['makePhoneCall',['$0'],['orderInfo.contactPhone']]]]]}}" class="info-value-wrapper data-v-57d42baa" bindtap="__e"><text class="info-value link data-v-57d42baa">{{orderInfo.contactPhone}}</text><uni-icons style="margin-left:8rpx;" vue-id="a2b0478a-3" type="phone-filled" size="16" color="#3ec6c6" class="data-v-57d42baa" bind:__l="__l"></uni-icons></view></view><view class="divider data-v-57d42baa"></view><view class="info-item data-v-57d42baa"><text class="info-label data-v-57d42baa">预约时间</text><view class="info-value-wrapper data-v-57d42baa"><text class="info-value data-v-57d42baa">{{orderInfo.appointmentDate+" "+orderInfo.appointmentPeriod}}</text></view></view><block wx:if="{{orderInfo.serviceAddress}}"><view class="divider data-v-57d42baa"></view><view class="info-item vertical data-v-57d42baa"><text class="info-label data-v-57d42baa">服务地址</text><view class="info-value-box data-v-57d42baa"><text class="info-value data-v-57d42baa">{{orderInfo.serviceAddress}}</text></view></view></block><block wx:if="{{orderInfo.remark}}"><view class="divider data-v-57d42baa"></view><view class="info-item vertical data-v-57d42baa"><text class="info-label data-v-57d42baa">备注信息</text><view class="info-value-box data-v-57d42baa"><text class="info-value data-v-57d42baa">{{orderInfo.remark}}</text></view></view></block></view></view></block><block wx:if="{{orderInfo}}"><view class="info-card data-v-57d42baa"><view class="card-header data-v-57d42baa"><view class="header-title data-v-57d42baa"><uni-icons class="header-icon data-v-57d42baa" vue-id="a2b0478a-4" type="wallet" size="18" color="#333" bind:__l="__l"></uni-icons><text class="data-v-57d42baa">费用明细</text></view></view><view class="price-list data-v-57d42baa"><view class="price-item data-v-57d42baa"><text class="price-label data-v-57d42baa">服务价格</text><text class="price-value data-v-57d42baa">{{"￥"+orderInfo.price}}</text></view><block wx:if="{{orderInfo.useSubsidy==='1'&&orderInfo.subsidyAmount>0}}"><view class="price-item data-v-57d42baa"><text class="price-label data-v-57d42baa">补贴金额</text><text class="price-value subsidy data-v-57d42baa">{{"-￥"+orderInfo.s