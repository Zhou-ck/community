<view class="order-container"><view class="order-tabs"><block wx:for="{{tabs}}" wx:for-item="tab" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['switchTab',[index]]]]]}}" class="{{['tab-item',(currentTab===index)?'active':'']}}" bindtap="__e"><text>{{tab}}</text></view></block></view><block wx:if="{{currentTab===0}}"><view class="search-container"><view class="search-box"><uni-icons vue-id="3bc35b9e-1" type="search" size="18" color="#999" bind:__l="__l"></uni-icons><input class="search-input" type="text" placeholder="搜索订单服务名称" data-event-opts="{{[['input',[['__set_model',['','searchKeyword','$event',[]]],['handleSearch',['$event']]]],['confirm',[['handleSearch',['$event']]]]]}}" value="{{searchKeyword}}" bindinput="__e" bindconfirm="__e"/><block wx:if="{{searchKeyword}}"><view data-event-opts="{{[['tap',[['clearSearch',['$event']]]]]}}" class="clear-btn" bindtap="__e"><uni-icons vue-id="3bc35b9e-2" type="clear" size="16" color="#999" bind:__l="__l"></uni-icons></view></block></view></view></block><block wx:if="{{currentTab===4}}"><view class="my-review-section"><view data-event-opts="{{[['tap',[['goToReviewCenter',['$event']]]]]}}" class="review-header" bindtap="__e"><view class="review-info"><image class="user-avatar" src="{{userInfo.avatar||'/static/images/profile.jpg'}}"></image><view class="user-detail"><text class="username">{{userInfo.nickname||'用户'}}</text><text class="review-stats">{{"已评价 "+reviewStats.totalReviews+" 条"}}</text></view></view><view class="review-action"><text class="action-text">我的评价</text><uni-icons vue-id="3bc35b9e-3" type="right" size="16" color="#999" bind:__l="__l"></uni-icons></view></view></view></block><scroll-view class="order-list" scroll-y="{{true}}" refresher-enabled="{{true}}" refresher-triggered="{{isRefreshing}}" data-event-opts="{{[['scrolltolower',[['loadMore',['$event']]]],['refresherrefresh',[['onRefresh',['$event']]]]]}}" bindscrolltolower="__e" bindrefresherrefresh="__e"><block wx:if="{{$root.g0===0}}"><view class="empty-order"><text class="iconfontA icon-fuwudingdan empty-image"></text><text class="empty-text">暂无相关服务订单</text></view></block><block wx:else><block wx:for="{{$root.l0}}" wx:for-item="order" wx:for-index="index" wx:key="index"><view class="order-item"><view class="order-header"><text class="order-time">{{order.$orig.createTime}}</text><text class="{{['order-status',order.$orig.statusClass]}}">{{order.$orig.statusText}}</text></view><view class="service-order-content"><view class="service-header"><image class="service-icon" src="{{order.m0}}" mode="aspectFill"></image><view class="service-info"><view class="service-name">{{order.$orig.serviceName||'服务项目'}}</view><view class="service-detail"><view class="detail-item"><uni-icons vue-id="{{'3bc35b9e-4-'+index}}" type="person" size="14" color="#999" bind:__l="__l"></uni-icons><text class="detail-text">{{"联系人："+order.$orig.contactName}}</text></view><view class="detail-item"><uni-icons vue-id="{{'3bc35b9e-5-'+index}}" type="phone" size="14" color="#999" bind:__l="__l"></uni-icons><text class="detail-text">{{order.$orig.contactPhone}}</text></view><view class="detail-item"><uni-icons vue-id="{{'3bc35b9e-6-'+index}}" type="calendar" size="14" color="#999" bind:__l="__l"></uni-icons><text class="detail-text">{{"预约时间："+order.$orig.appointmentDate+" "+order.$orig.appointmentPeriod}}</text></view><block wx:if="{{order.$orig.serviceAddress}}"><view class="detail-item"><uni-icons vue-id="{{'3bc35b9e-7-'+index}}" type="location" size="14" color="#999" bind:__l="__l"></uni-icons><text class="detail-text">{{"服务地址："+order.$orig.serviceAddress}}</text></view></block></view></view></view></view><view class="order-footer"><view class="order-summary"><text class="total-text">{{"服务价格：￥"+order.$orig.price}}</text><block wx:if="{{order.$orig.useSubsidy==='1'&&order.$orig.subsidyAmount>0}}"><text class="subsidy-text">{{"补贴：-￥"+order.$orig.subsidyAmount}}</text></block><view class="amount-wrapper"><text class="{{['total-price',(order.$orig.status==='cancelled'||order.$orig.status==='rejected')?'refunded':'']}}">{{'实付：￥'+order.$orig.actualAmount+''}}</text><block wx:if="{{order.$orig.status==='cancelled'||order.$orig.status==='rejected'}}"><text class="refund-tag">已退款</text></block></view></view><view class="order-actions"><block wx:if="{{order.$orig.status==='pending'}}"><button data-event-opts="{{[['tap',[['deleteOrder',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn delete" bindtap="__e">删除订单</button><button data-event-opts="{{[['tap',[['editOrder',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn secondary" bindtap="__e">修改预约</button><button data-event-opts="{{[['tap',[['cancelOrder',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn cancel" bindtap="__e">取消预约</button></block><block wx:if="{{order.$orig.status==='accepted'}}"><button data-event-opts="{{[['tap',[['deleteOrder',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn delete" bindtap="__e">删除订单</button></block><block wx:if="{{order.$orig.status==='serving'}}"><button data-event-opts="{{[['tap',[['viewOrderDetail',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn secondary" bindtap="__e">查看详情</button><button data-event-opts="{{[['tap',[['confirmComplete',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn primary" bindtap="__e">确认完成</button></block><block wx:if="{{order.$orig.status==='completed'&&!order.$orig.isReviewed}}"><button data-event-opts="{{[['tap',[['viewOrderDetail',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn secondary" bindtap="__e">查看详情</button><button data-event-opts="{{[['tap',[['goToReview',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn review" bindtap="__e">立即评价</button></block><block wx:if="{{order.$orig.status==='completed'&&order.$orig.isReviewed}}"><button data-event-opts="{{[['tap',[['viewOrderDetail',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn secondary" bindtap="__e">查看详情</button><button data-event-opts="{{[['tap',[['viewMyReview',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn reviewed" bindtap="__e">查看评价</button></block><block wx:if="{{order.$orig.status==='cancelled'||order.$orig.status==='rejected'}}"><button data-event-opts="{{[['tap',[['deleteOrder',['$0'],[[['orderList','',index,'id']]]]]]]}}" class="action-btn delete" bindtap="__e">删除订单</button></block></view></view></view></block></block><block wx:if="{{isLoading}}"><view class="loading-more"><uni-icons vue-id="3bc35b9e-8" type="spinner-cycle" size="24" color="#999" bind:__l="__l"></uni-icons><text>加载中...</text></view></block><block wx:if="{{$root.g1}}"><view class="no-more"><text>没有更多订单了</text></view></block></scroll-view><block wx:if="{{showReviewModal}}"><view data-event-opts="{{[['tap',[['closeReviewModal',['$event']]]]]}}" class="review-modal" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="review-content" catchtap="__e"><view class="review-header"><text class="review-title">服务评价</text><uni-icons vue-id="3bc35b9e-9" type="closeempty" size="24" color="#999" data-event-opts="{{[['^click',[['closeReviewModal']]]]}}" bind:click="__e" bind:__l="__l"></uni-icons></view><view class="review-body"><view class="review-item"><text class="review-label">服务评分</text><view class="star-rating"><block wx:for="{{5}}" wx:for-item="star" wx:for-index="__i0__" wx:key="*this"><uni-icons vue-id="{{'3bc35b9e-10-'+__i0__}}" type="{{star<=reviewData.rating?'star-filled':'star'}}" size="32" color="{{star<=reviewData.rating?'#FFB400':'#E0E0E0'}}" data-event-opts="{{[['^click',[['setRating',['$0'],[[[5,'',__i0__]]]]]]]}}" bind:click="__e" bind:__l="__l"></uni-icons></block></view></view><view class="review-item"><text class="review-label">评价内容</text><textarea class="review-textarea" placeholder="请描述您对本次服务的评价" maxlength="200" auto-height="{{true}}" data-event-opts="{{[['input',[['__set_model',['$0','content','$event',[]],['reviewData']]]]]}}" value="{{reviewData.content}}" bindinput="__e"></textarea><text class="char-count">{{$root.g2+"/200"}}</text></view></view><view class="review-footer"><button data-event-opts="{{[['tap',[['closeReviewModal',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</button><button class="submit-btn" loading="{{submittingReview}}" data-event-opts="{{[['tap',[['submitReview',['$event']]]]]}}" bindtap="__e">提交评价</button></view></view></view></block></view>