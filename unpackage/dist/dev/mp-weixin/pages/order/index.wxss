.order-container {
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}
.order-tabs {
  display: flex;
  background-color: #fff;
  padding: 10rpx 0;
  flex-shrink: 0;
  /* 不允许收缩 */
  z-index: 100;
}
.order-tabs .tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
  padding: 20rpx 0;
}
.order-tabs .tab-item.active {
  color: #3ec6c6;
  font-weight: 500;
}
.order-tabs .tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  -webkit-transform: translateX(-50%);
          transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #3ec6c6;
  border-radius: 2rpx;
}
.search-container {
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  /* 不允许收缩 */
  z-index: 99;
}
.search-container .search-box {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 16rpx 20rpx;
  position: relative;
}
.search-container .search-box .search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  margin-left: 16rpx;
  background: transparent;
  border: none;
  outline: none;
}
.search-container .search-box .search-input::-webkit-input-placeholder {
  color: #999;
}
.search-container .search-box .search-input::placeholder {
  color: #999;
}
.search-container .search-box .clear-btn {
  margin-left: 16rpx;
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.my-review-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
  /* 不允许收缩 */
}
.my-review-section .review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
}
.my-review-section .review-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.my-review-section .user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  border: 2rpx solid #f0f0f0;
}
.my-review-section .user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.my-review-section .username {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.my-review-section .review-stats {
  font-size: 24rpx;
  color: #999;
}
.my-review-section .review-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.my-review-section .action-text {
  font-size: 28rpx;
  color: #666;
}
.order-list {
  flex: 1;
  padding: 20rpx;
  height: 0;
  /* 关键：配合flex布局，让scroll-view正确计算高度 */
}
.empty-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
}
.empty-order .empty-image {
  font-size: 160rpx;
  margin-bottom: 32rpx;
  color: #ff9db5;
  opacity: 0.8;
}
.empty-order .empty-text {
  font-size: 28rpx;
  color: #999;
  letter-spacing: 1rpx;
}
.order-item {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.order-item .order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}
.order-item .order-header .order-time {
  font-size: 24rpx;
  color: #999;
}
.order-item .order-header .order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.order-item .order-header .order-status.status-pending {
  color: #ff9900;
  background: rgba(255, 153, 0, 0.1);
}
.order-item .order-header .order-status.status-accepted {
  color: #2979ff;
  background: rgba(41, 121, 255, 0.1);
}
.order-item .order-header .order-status.status-serving {
  color: #0ac160;
  background: rgba(10, 193, 96, 0.1);
}
.order-item .order-header .order-status.status-shipping {
  color: #0ac160;
  background: rgba(10, 193, 96, 0.1);
}
.order-item .order-header .order-status.status-received {
  color: #9c27b0;
  background: rgba(156, 39, 176, 0.1);
}
.order-item .order-header .order-status.status-completed {
  color: #666666;
  background: #f5f5f5;
}
.order-item .order-header .order-status.status-cancelled {
  color: #999999;
  background: #f5f5f5;
}
.order-item .order-header .order-status.status-rejected {
  color: #ff5722;
  background: rgba(255, 87, 34, 0.1);
}
.order-item .order-header .order-status.status-refunded {
  color: #ff5722;
  background: rgba(255, 87, 34, 0.1);
}
.order-item .service-order-content {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  margin: 16rpx 0;
}
.order-item .service-order-content .service-header {
  display: flex;
  gap: 20rpx;
}
.order-item .service-order-content .service-header .service-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #fff;
}
.order-item .service-order-content .service-header .service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.order-item .service-order-content .service-header .service-info .service-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.3;
}
.order-item .service-order-content .service-header .service-info .service-detail .detail-item {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}
.order-item .service-order-content .service-header .service-info .service-detail .detail-item:last-child {
  margin-bottom: 0;
}
.order-item .service-order-content .service-header .service-info .service-detail .detail-item .detail-text {
  font-size: 24rpx;
  color: #666;
  margin-left: 8rpx;
  line-height: 1.4;
}
.order-item .order-footer {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-end;
  border-top: 2rpx solid #f5f5f5;
  padding-top: 10rpx;
}
.order-item .order-footer .order-summary {
  width: 100%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.order-item .order-footer .order-summary .total-text {
  font-size: 26rpx;
  color: #666;
}
.order-item .order-footer .order-summary .subsidy-text {
  font-size: 24rpx;
  color: #52c41a;
}
.order-item .order-footer .order-summary .amount-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.order-item .order-footer .order-summary .total-price {
  font-size: 32rpx;
  color: #ff5555;
  font-weight: bold;
}
.order-item .order-footer .order-summary .total-price.refunded {
  color: #999;
  text-decoration: line-through;
}
.order-item .order-footer .order-summary .refund-tag {
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  color: #52c41a;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 8rpx;
  line-height: 1.2;
}
.order-item .order-footer .order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}
.order-item .order-footer .order-actions .action-btn {
  padding: 0 38rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(62, 198, 198, 0.08);
  transition: box-shadow 0.2s, background 0.2s, color 0.2s;
  margin-right: 0;
  margin-left: 0;
  margin-bottom: 0;
  margin-top: 0;
  min-width: 120rpx;
  white-space: nowrap;
  text-overflow: initial;
}
.order-item .order-footer .order-actions .action-btn:active {
  box-shadow: 0 1rpx 4rpx rgba(62, 198, 198, 0.12);
  opacity: 0.92;
}
.order-item .order-footer .order-actions .action-btn.primary {
  color: #fff;
  background: #ff5555;
  border: none;
}
.order-item .order-footer .order-actions .action-btn.cancel, .order-item .order-footer .order-actions .action-btn.secondary, .order-item .order-footer .order-actions .action-btn.remind, .order-item .order-footer .order-actions .action-btn.review, .order-item .order-footer .order-actions .action-btn.test-ship, .order-item .order-footer .order-actions .action-btn.test-review {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  color: #3ec6c6;
}
.order-item .order-footer .order-actions .action-btn.cancel {
  color: #999;
  border-color: #e0e0e0;
}
.order-item .order-footer .order-actions .action-btn.remind {
  color: #ff9900;
  border-color: #ffe0b2;
}
.order-item .order-footer .order-actions .action-btn.review {
  color: #9c27b0;
  border-color: #e1bee7;
}
.order-item .order-footer .order-actions .action-btn.delete {
  color: #ff5555;
  border-color: #ffcdd2;
}
.order-item .order-footer .order-actions .action-btn.reviewed {
  color: #666;
  border-color: #ddd;
  background: #f8f8f8;
}
.order-item .order-footer .order-actions .action-btn.test-ship {
  color: #3ec6c6;
  border-color: #b2ebf2;
}
.order-item .order-footer .order-actions .action-btn.test-review {
  color: #67c23a;
  border-color: #d0f5e0;
}
.order-item .order-footer .order-actions .action-btn[disabled] {
  color: #bbb !important;
  background: #f5f5f5 !important;
  border-color: #eee !important;
}
.order-item .logistics-info {
  margin-top: 20rpx;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e6f7ff 100%);
  border-radius: 12rpx;
  border-left: 4rpx solid #67c23a;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}
.order-item .logistics-info::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  background: rgba(103, 194, 58, 0.1);
  border-radius: 0 12rpx 0 60rpx;
}
.order-item .logistics-info .logistics-header {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}
.order-item .logistics-info .logistics-header .logistics-status {
  font-size: 28rpx;
  color: #67c23a;
  font-weight: 600;
  white-space: nowrap;
}
.order-item .logistics-info .logistics-header .logistics-detail {
  font-size: 24rpx;
  color: #666;
  flex: 1;
  line-height: 1.4;
  margin-top: 2rpx;
}
.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-more uni-icons, .no-more uni-icons {
  margin-right: 10rpx;
}
.order-card {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin: 24rpx 20rpx;
  padding: 28rpx 24rpx 20rpx 24rpx;
  font-size: 28rpx;
}
.order-card .order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}
.order-card .order-header .order-status {
  color: #ff9800;
  font-weight: bold;
  font-size: 30rpx;
}
.order-card .order-header .order-number {
  color: #bbb;
  font-size: 24rpx;
}
.order-card .order-body .order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.order-card .order-body .order-info .order-total {
  color: #333;
}
.order-card .order-body .order-info .order-total .price {
  color: #ff5555;
  font-weight: bold;
  font-size: 32rpx;
}
.order-card .order-body .order-logistics {
  color: #888;
  font-size: 26rpx;
}
.order-card .order-body .order-logistics .logistics-number {
  color: #3ec6c6;
  font-weight: bold;
}
.order-card .order-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}
.order-card .order-actions button {
  margin-left: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 0 32rpx;
  height: 56rpx;
  line-height: 56rpx;
  border: none;
}
.order-card .order-actions button.btn-more {
  background: #f5f5f5;
  color: #666;
}
.order-card .order-actions button.btn-normal {
  background: #fff;
  color: #3ec6c6;
  border: 1rpx solid #3ec6c6;
}
.order-card .order-actions button.btn-confirm {
  background: linear-gradient(90deg, #3ec6c6, #36b3b3);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(62, 198, 198, 0.12);
}
.review-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.review-modal .review-content {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.review-modal .review-content .review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
}
.review-modal .review-content .review-header .review-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.review-modal .review-content .review-body {
  padding: 32rpx;
}
.review-modal .review-content .review-body .review-item {
  margin-bottom: 32rpx;
}
.review-modal .review-content .review-body .review-item:last-child {
  margin-bottom: 0;
}
.review-modal .review-content .review-body .review-item .review-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}
.review-modal .review-content .review-body .review-item .star-rating {
  display: flex;
  gap: 12rpx;
}
.review-modal .review-content .review-body .review-item .review-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.review-modal .review-content .review-body .review-item .char-count {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
}
.review-modal .review-content .review-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
}
.review-modal .review-content .review-footer button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}
.review-modal .review-content .review-footer button.cancel-btn {
  background: #f5f5f5;
  color: #666;
}
.review-modal .review-content .review-footer button.submit-btn {
  background: linear-gradient(135deg, #3ec6c6 0%, #36b3b3 100%);
  color: #fff;
}

