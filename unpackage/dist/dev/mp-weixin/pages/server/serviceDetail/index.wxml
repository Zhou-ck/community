<view class="service-detail-page data-v-4b1444d6"><scroll-view class="detail-content data-v-4b1444d6" scroll-y="{{true}}"><view class="service-banner data-v-4b1444d6"><image class="banner-image data-v-4b1444d6" src="{{$root.m0}}" mode="aspectFill"></image></view><view class="service-info-card data-v-4b1444d6"><view class="service-header data-v-4b1444d6"><view class="service-name data-v-4b1444d6">{{serviceData.serviceName}}</view><view class="service-price-wrapper data-v-4b1444d6"><text class="price-symbol data-v-4b1444d6">¥</text><text class="price-amount data-v-4b1444d6">{{serviceData.price}}</text><text class="price-unit data-v-4b1444d6">/次</text></view></view><view class="service-tags data-v-4b1444d6"><block wx:if="{{serviceData.subsidySupport==='1'}}"><view class="tag-item data-v-4b1444d6"><uni-icons vue-id="1774d6f0-1" type="checkmarkempty" size="12" color="#52c41a" class="data-v-4b1444d6" bind:__l="__l"></uni-icons><text class="data-v-4b1444d6">可补贴</text></view></block><block wx:if="{{serviceData.serviceDuration}}"><view class="tag-item data-v-4b1444d6"><uni-icons vue-id="1774d6f0-2" type="clock" size="12" color="#1890ff" class="data-v-4b1444d6" bind:__l="__l"></uni-icons><text class="data-v-4b1444d6">{{serviceData.serviceDuration+"分钟"}}</text></view></block></view><block wx:if="{{serviceData.subsidySupport==='1'&&serviceData.subsidyRate>0}}"><view class="subsidy-info data-v-4b1444d6"><view class="subsidy-icon data-v-4b1444d6"><text class="iconfontA icon-butie data-v-4b1444d6"></text></view><view class="subsidy-text data-v-4b1444d6"><text class="subsidy-label data-v-4b1444d6">补贴优惠</text><text class="subsidy-rate data-v-4b1444d6">{{"补贴"+serviceData.subsidyRate+"%，实付¥"+actualAmount}}</text></view></view></block></view><block wx:if="{{serviceData.description}}"><view class="detail-section data-v-4b1444d6"><view class="section-title data-v-4b1444d6">服务描述</view><view class="section-content data-v-4b1444d6"><text class="description-text data-v-4b1444d6">{{serviceData.description}}</text></view></view></block><block wx:if="{{serviceData.serviceContent}}"><view class="detail-section data-v-4b1444d6"><view class="section-title data-v-4b1444d6">服务内容</view><view class="section-content data-v-4b1444d6"><text class="content-text data-v-4b1444d6">{{serviceData.serviceContent}}</text></view></view></block><view class="detail-section data-v-4b1444d6"><view class="section-title data-v-4b1444d6">服务须知</view><view class="section-content data-v-4b1444d6"><view class="notice-item data-v-4b1444d6"><text class="notice-dot data-v-4b1444d6">•</text><text class="notice-text data-v-4b1444d6">请提前预约服务时间，我们会尽快安排服务人员</text></view><view class="notice-item data-v-4b1444d6"><text class="notice-dot data-v-4b1444d6">•</text><text class="notice-text data-v-4b1444d6">如需取消或修改预约，请提前联系客服</text></view><view class="notice-item data-v-4b1444d6"><text class="notice-dot data-v-4b1444d6">•</text><text class="notice-text data-v-4b1444d6">服务完成后请及时评价，帮助我们提升服务质量</text></view><block wx:if="{{serviceData.subsidySupport==='1'}}"><view class="notice-item data-v-4b1444d6"><text class="notice-dot data-v-4b1444d6">•</text><text class="notice-text data-v-4b1444d6">补贴金额将在订单完成后自动计算并抵扣</text></view></block></view></view><view class="bottom-placeholder data-v-4b1444d6"></view></scroll-view><view class="bottom-bar data-v-4b1444d6"><view class="price-info data-v-4b1444d6"><view class="price-label data-v-4b1444d6">服务价格</view><view class="price-wrapper data-v-4b1444d6"><text class="current-price data-v-4b1444d6">{{"¥"+serviceData.price}}</text><block wx:if="{{serviceData.subsidySupport==='1'&&serviceData.subsidyRate>0}}"><text class="actual-price data-v-4b1444d6">{{'实付¥'+actualAmount+''}}</text></block></view></view><button data-event-opts="{{[['tap',[['goToBooking',['$event']]]]]}}" class="booking-btn data-v-4b1444d6" bindtap="__e">立即预约</button></view></view>