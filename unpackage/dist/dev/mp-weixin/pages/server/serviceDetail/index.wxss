  justify-content: center;
  flex-shrink: 0;
}
.service-info-card .subsidy-info .subsidy-icon .iconfontA.data-v-4b1444d6 {
  font-size: 32rpx;
  color: #fff;
}
.service-info-card .subsidy-info .subsidy-text.data-v-4b1444d6 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.service-info-card .subsidy-info .subsidy-text .subsidy-label.data-v-4b1444d6 {
  font-size: 28rpx;
  color: #d46b08;
  font-weight: 600;
}
.service-info-card .subsidy-info .subsidy-text .subsidy-rate.data-v-4b1444d6 {
  font-size: 24rpx;
  color: #ad6800;
}
