/* 文章场景相关 */
.service-detail-page.data-v-4b1444d6 {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}
/* 详情内容 */
.detail-content.data-v-4b1444d6 {
  flex: 1;
  padding-bottom: 140rpx;
}
/* 服务图片 */
.service-banner.data-v-4b1444d6 {
  width: 100%;
  height: 500rpx;
  background: #fff;
}
.service-banner .banner-image.data-v-4b1444d6 {
  width: 100%;
  height: 100%;
}
/* 服务基本信息卡片 */
.service-info-card.data-v-4b1444d6 {
  background: #fff;
  margin-top: 20rpx;
  padding: 32rpx;
}
.service-info-card .service-header.data-v-4b1444d6 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}
.service-info-card .service-header .service-name.data-v-4b1444d6 {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-right: 20rpx;
}
.service-info-card .service-header .service-price-wrapper.data-v-4b1444d6 {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}
.service-info-card .service-header .service-price-wrapper .price-symbol.data-v-4b1444d6 {
  font-size: 28rpx;
  color: #ff5555;
