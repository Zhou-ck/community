  color: #52c41a;
}
.bottom-bar .booking-btn.data-v-4b1444d6 {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #3ec6c6 0%, #2ab5b5 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
